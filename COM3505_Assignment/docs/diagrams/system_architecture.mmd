        Browser["Dashboard UI"]
    end

    Browser -- "AJAX polling<br/>GET /api/state + GET /api/history" --> Flask
    Browser -- "User controls<br/>POST /api/pattern + POST /api/mode" --> Flask

    Flask --> History["Latest readings<br/>and recent history"]
    History --> Flask
